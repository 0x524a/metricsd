#!/bin/bash
# nerdctl metrics plugin for metricsd
# Collects comprehensive container status and resource usage from nerdctl/containerd
#
# Metrics collected:
# - nerdctl_available: Whether nerdctl is installed (0/1)
# - containers_total/running/paused/stopped: Aggregate container counts
# - container_info: Container metadata (running state, image, image_name, image_tag, created time)
# - container_cpu_percent: CPU usage percentage per container
# - container_memory_usage_bytes: Memory usage in bytes
# - container_memory_limit_bytes: Memory limit in bytes
# - container_memory_percent: Memory usage percentage
# - container_network_rx_bytes: Network bytes received
# - container_network_tx_bytes: Network bytes transmitted
# - container_block_read_bytes: Block I/O read bytes
# - container_block_write_bytes: Block I/O write bytes
# - container_pids: Number of processes in container
#
# Labels for container metrics include:
# - container_id: Container ID
# - container_name: Container name
# - image: Full image name with tag (e.g., nginx:latest)
# - image_name: Image name without tag (e.g., nginx)
# - image_tag: Image tag (e.g., latest, 1.21, v2.0)
#
# Output format: JSON array of metrics following the plugin schema

set -e

# Start JSON array
echo "["

first=true

# Function to output a metric
output_metric() {
    local name="$1"
    local value="$2"
    local type="${3:-gauge}"
    local labels="$4"

    if [ "$first" = true ]; then
        first=false
    else
        echo ","
    fi

    if [ -n "$labels" ]; then
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\", \"labels\": {$labels}}"
    else
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\"}"
    fi
}

# Function to convert human-readable size to bytes
parse_size() {
    local size="$1"
    local num unit

    # Handle "--" or empty
    if [ -z "$size" ] || [ "$size" = "--" ]; then
        echo "0"
        return
    fi

    # Extract number and unit
    num=$(echo "$size" | sed 's/[^0-9.]//g')
    unit=$(echo "$size" | sed 's/[0-9.]//g' | tr '[:lower:]' '[:upper:]')

    # Handle empty number
    if [ -z "$num" ]; then
        echo "0"
        return
    fi

    case "$unit" in
        B|"")   echo "$num" ;;
        KB|KIB) echo "$(echo "$num * 1024" | bc 2>/dev/null || echo 0)" ;;
        MB|MIB) echo "$(echo "$num * 1048576" | bc 2>/dev/null || echo 0)" ;;
        GB|GIB) echo "$(echo "$num * 1073741824" | bc 2>/dev/null || echo 0)" ;;
        TB|TIB) echo "$(echo "$num * 1099511627776" | bc 2>/dev/null || echo 0)" ;;
        *)      echo "$num" ;;
    esac
}

# Function to parse network/block I/O (format: "1.5MB / 2.3GB")
parse_io() {
    local io="$1"
    local direction="$2"  # "rx" or "tx" / "read" or "write"

    if [ -z "$io" ] || [ "$io" = "--" ]; then
        echo "0"
        return
    fi

    local value
    if [ "$direction" = "rx" ] || [ "$direction" = "read" ]; then
        value=$(echo "$io" | cut -d'/' -f1 | tr -d ' ')
    else
        value=$(echo "$io" | cut -d'/' -f2 | tr -d ' ')
    fi

    parse_size "$value"
}

# Function to escape string for JSON
json_escape() {
    echo "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g; s/\n/\\n/g'
}

# Check if nerdctl is available
if ! command -v nerdctl &> /dev/null; then
    output_metric "nerdctl_available" 0 "gauge" ""
    echo ""
    echo "]"
    exit 0
fi

# nerdctl is available
output_metric "nerdctl_available" 1 "gauge" ""

# Get container count by status
total_containers=0
running_containers=0
paused_containers=0
stopped_containers=0

# Declare associative arrays for container info (if supported)
declare -A container_images 2>/dev/null || true
declare -A container_names 2>/dev/null || true
declare -A container_created 2>/dev/null || true

# Try to auto-detect namespace if NERDCTL_NAMESPACE is not set
# Common namespaces: k8s.io, default, moby
NERDCTL_ARGS=""
if [ -n "$NERDCTL_NAMESPACE" ]; then
    NERDCTL_ARGS="-n $NERDCTL_NAMESPACE"
else
    # Try common namespaces to find containers
    for ns in "k8s.io" "default" ""; do
        if [ -n "$ns" ]; then
            test_count=$(nerdctl -n "$ns" ps -a -q 2>/dev/null | wc -l)
            if [ "$test_count" -gt 0 ]; then
                NERDCTL_ARGS="-n $ns"
                break
            fi
        else
            test_count=$(nerdctl ps -a -q 2>/dev/null | wc -l)
            if [ "$test_count" -gt 0 ]; then
                NERDCTL_ARGS=""
                break
            fi
        fi
    done
fi

# Get detailed container info
while IFS= read -r line; do
    if [ -z "$line" ]; then
        continue
    fi

    # Parse container info (format: ID|Name|Image|Status|CreatedAt)
    id=$(echo "$line" | cut -d'|' -f1)
    name=$(echo "$line" | cut -d'|' -f2)
    image=$(echo "$line" | cut -d'|' -f3)
    status=$(echo "$line" | cut -d'|' -f4)
    created=$(echo "$line" | cut -d'|' -f5)

    ((total_containers++)) || true

    # Determine status
    running=0
    status_label="stopped"
    if [[ "$status" == *"Up"* ]]; then
        ((running_containers++)) || true
        running=1
        status_label="running"
    elif [[ "$status" == *"Paused"* ]]; then
        ((paused_containers++)) || true
        status_label="paused"
    else
        ((stopped_containers++)) || true
    fi

    # Escape for JSON
    safe_name=$(json_escape "$name")
    safe_id=$(json_escape "$id")
    safe_image=$(json_escape "$image")

    # Extract image name and tag
    # Format: image:tag or registry/image:tag
    if [[ "$image" == *":"* ]]; then
        image_name="${image%:*}"
        image_tag="${image##*:}"
    else
        image_name="$image"
        image_tag="latest"
    fi
    safe_image_name=$(json_escape "$image_name")
    safe_image_tag=$(json_escape "$image_tag")

    # Store container info for later use with stats
    container_names["$id"]="$safe_name" 2>/dev/null || true
    container_images["$id"]="$safe_image" 2>/dev/null || true
    container_images["${id}_name"]="$safe_image_name" 2>/dev/null || true
    container_images["${id}_tag"]="$safe_image_tag" 2>/dev/null || true

    # Output per-container info metric
    labels="\"container_id\": \"$safe_id\", \"container_name\": \"$safe_name\", \"image\": \"$safe_image\", \"image_name\": \"$safe_image_name\", \"image_tag\": \"$safe_image_tag\", \"status\": \"$status_label\""
    output_metric "container_info" "$running" "gauge" "$labels"

done < <(nerdctl $NERDCTL_ARGS ps -a --format "{{.ID}}|{{.Names}}|{{.Image}}|{{.Status}}|{{.CreatedAt}}" 2>/dev/null || true)

# Output aggregate container counts
output_metric "containers_total" "$total_containers" "gauge" ""
output_metric "containers_running" "$running_containers" "gauge" ""
output_metric "containers_paused" "$paused_containers" "gauge" ""
output_metric "containers_stopped" "$stopped_containers" "gauge" ""

# Get detailed resource stats for running containers
if [ "$running_containers" -gt 0 ]; then
    # Use nerdctl stats with --no-stream and parse the output
    # Format: CONTAINER ID  NAME  CPU %  MEM USAGE / LIMIT  MEM %  NET I/O  BLOCK I/O  PIDS

    while IFS= read -r line; do
        # Skip header line or empty lines
        if [[ "$line" == "CONTAINER"* ]] || [ -z "$line" ]; then
            continue
        fi

        # Parse stats - nerdctl stats output is space-separated but columns have fixed positions
        # We need to be careful with parsing as values can have spaces
        id=$(echo "$line" | awk '{print $1}')
        # Note: Don't parse name from stats output - it may be truncated
        # We'll get it from the associative array instead
        cpu=$(echo "$line" | awk '{print $3}' | tr -d '%')

        # Memory usage and limit (columns 4-6: "123MiB / 456GiB")
        mem_usage=$(echo "$line" | awk '{print $4}')
        mem_limit=$(echo "$line" | awk '{print $6}')
        mem_pct=$(echo "$line" | awk '{print $7}' | tr -d '%')

        # Network I/O (columns 8-10: "1.5MB / 2.3GB")
        net_io=$(echo "$line" | awk '{print $8 " " $9 " " $10}')

        # Block I/O (columns 11-13: "1.5MB / 2.3GB")
        block_io=$(echo "$line" | awk '{print $11 " " $12 " " $13}')

        # PIDs (column 14)
        pids=$(echo "$line" | awk '{print $14}')

        # Skip if we couldn't parse ID
        if [ -z "$id" ] || [ "$id" = "--" ]; then
            continue
        fi

        # Get full container name and image info from earlier container info
        safe_name="${container_names[$id]:-unknown}"
        safe_id=$(json_escape "$id")
        safe_image="${container_images[$id]:-unknown}"
        safe_image_name="${container_images[${id}_name]:-unknown}"
        safe_image_tag="${container_images[${id}_tag]:-unknown}"

        labels="\"container_id\": \"$safe_id\", \"container_name\": \"$safe_name\", \"image\": \"$safe_image\", \"image_name\": \"$safe_image_name\", \"image_tag\": \"$safe_image_tag\""

        # Output CPU metric
        if [ -n "$cpu" ] && [ "$cpu" != "--" ]; then
            output_metric "container_cpu_percent" "$cpu" "gauge" "$labels"
        fi

        # Output memory metrics
        if [ -n "$mem_usage" ] && [ "$mem_usage" != "--" ]; then
            mem_usage_bytes=$(parse_size "$mem_usage")
            output_metric "container_memory_usage_bytes" "$mem_usage_bytes" "gauge" "$labels"
        fi

        if [ -n "$mem_limit" ] && [ "$mem_limit" != "--" ]; then
            mem_limit_bytes=$(parse_size "$mem_limit")
            output_metric "container_memory_limit_bytes" "$mem_limit_bytes" "gauge" "$labels"
        fi

        if [ -n "$mem_pct" ] && [ "$mem_pct" != "--" ]; then
            output_metric "container_memory_percent" "$mem_pct" "gauge" "$labels"
        fi

        # Output network I/O metrics
        if [ -n "$net_io" ] && [ "$net_io" != "--" ]; then
            net_rx=$(parse_io "$net_io" "rx")
            net_tx=$(parse_io "$net_io" "tx")
            output_metric "container_network_rx_bytes" "$net_rx" "counter" "$labels"
            output_metric "container_network_tx_bytes" "$net_tx" "counter" "$labels"
        fi

        # Output block I/O metrics
        if [ -n "$block_io" ] && [ "$block_io" != "--" ]; then
            block_read=$(parse_io "$block_io" "read")
            block_write=$(parse_io "$block_io" "write")
            output_metric "container_block_read_bytes" "$block_read" "counter" "$labels"
            output_metric "container_block_write_bytes" "$block_write" "counter" "$labels"
        fi

        # Output PIDs metric
        if [ -n "$pids" ] && [ "$pids" != "--" ]; then
            output_metric "container_pids" "$pids" "gauge" "$labels"
        fi

    done < <(nerdctl $NERDCTL_ARGS stats --no-stream 2>/dev/null || true)
fi

# Close JSON array
echo ""
echo "]"
