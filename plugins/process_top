#!/bin/bash
# process_top metrics plugin for metricsd
# Collects top N processes by CPU and memory usage
#
# Metrics collected:
# - process_top_available: Whether ps command is available (0/1)
# - process_cpu_percent: CPU usage percentage per process (top N)
# - process_memory_percent: Memory usage percentage per process (top N)
# - process_memory_rss_bytes: Resident Set Size in bytes per process (top N)
# - process_memory_vsz_bytes: Virtual memory size in bytes per process (top N)
# - process_threads: Number of threads per process (top N, Linux only)
#
# Configuration via environment variables:
# - PROCESS_TOP_N: Number of top processes to report (default: 10)
# - PROCESS_INCLUDE_THREADS: Include thread count (default: true)
#
# Output format: JSON array of metrics following the plugin schema

set -e

# Configuration
TOP_N="${PROCESS_TOP_N:-10}"
INCLUDE_THREADS="${PROCESS_INCLUDE_THREADS:-true}"

# Start JSON array
echo "["

first=true

# Function to output a metric
output_metric() {
    local name="$1"
    local value="$2"
    local type="${3:-gauge}"
    local labels="$4"

    # Skip if value is empty or not a number
    if [ -z "$value" ] || ! [[ "$value" =~ ^-?[0-9]+\.?[0-9]*$ ]]; then
        return
    fi

    if [ "$first" = true ]; then
        first=false
    else
        echo ","
    fi

    if [ -n "$labels" ]; then
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\", \"labels\": {$labels}}"
    else
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\"}"
    fi
}

# Function to escape string for JSON
json_escape() {
    echo "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g; s/\r/\\r/g'
}

# Check if ps command is available
if ! command -v ps &> /dev/null; then
    output_metric "process_top_available" 0 "gauge" ""
    echo ""
    echo "]"
    exit 0
fi

output_metric "process_top_available" 1 "gauge" ""

# Use a string to track reported PIDs (bash 3.x compatible)
reported_pids=""

# Function to check if PID was already reported
is_reported() {
    local pid="$1"
    case "$reported_pids" in
        *":$pid:"*) return 0 ;;
        *) return 1 ;;
    esac
}

# Function to mark PID as reported
mark_reported() {
    local pid="$1"
    reported_pids="${reported_pids}:${pid}:"
}

# Determine the platform for ps options
if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS - sort by CPU descending
    PS_CMD="ps -axo pid,ppid,user,%cpu,%mem,rss,vsz,comm -r"
else
    # Linux
    PS_CMD="ps -eo pid,ppid,user,%cpu,%mem,rss,vsz,nlwp,comm --sort=-%cpu"
fi

# Get top processes by CPU
cpu_count=0
while IFS= read -r line; do
    # Skip header line
    if [[ "$line" =~ ^[[:space:]]*PID ]]; then
        continue
    fi

    # Skip empty lines
    [ -z "$line" ] && continue

    # Parse fields using awk
    pid=$(echo "$line" | awk '{print $1}')
    ppid=$(echo "$line" | awk '{print $2}')
    user=$(echo "$line" | awk '{print $3}')
    cpu=$(echo "$line" | awk '{print $4}')
    mem=$(echo "$line" | awk '{print $5}')
    rss=$(echo "$line" | awk '{print $6}')
    vsz=$(echo "$line" | awk '{print $7}')

    if [[ "$OSTYPE" == "darwin"* ]]; then
        comm=$(echo "$line" | awk '{for(i=8;i<=NF;i++) printf "%s ", $i; print ""}' | sed 's/[[:space:]]*$//')
        nlwp=""
    else
        nlwp=$(echo "$line" | awk '{print $8}')
        comm=$(echo "$line" | awk '{for(i=9;i<=NF;i++) printf "%s ", $i; print ""}' | sed 's/[[:space:]]*$//')
    fi

    # Skip kernel processes (PID 0) and idle
    [ "$pid" = "0" ] && continue
    [[ "$comm" == *"idle"* ]] && continue

    # Skip if CPU is 0.0 (not actively using CPU)
    [ "$cpu" = "0.0" ] && continue

    # Mark as reported
    mark_reported "$pid"

    # Escape for JSON
    safe_comm=$(json_escape "$comm")
    safe_user=$(json_escape "$user")
    labels="\"pid\": \"$pid\", \"ppid\": \"$ppid\", \"user\": \"$safe_user\", \"command\": \"$safe_comm\""

    # Output metrics
    output_metric "process_cpu_percent" "$cpu" "gauge" "$labels"
    output_metric "process_memory_percent" "$mem" "gauge" "$labels"

    # RSS is in KB, convert to bytes
    if [ -n "$rss" ] && [ "$rss" != "-" ]; then
        rss_bytes=$((rss * 1024))
        output_metric "process_memory_rss_bytes" "$rss_bytes" "gauge" "$labels"
    fi

    # VSZ is in KB, convert to bytes
    if [ -n "$vsz" ] && [ "$vsz" != "-" ]; then
        vsz_bytes=$((vsz * 1024))
        output_metric "process_memory_vsz_bytes" "$vsz_bytes" "gauge" "$labels"
    fi

    # Thread count (Linux only)
    if [ -n "$nlwp" ] && [ "$nlwp" != "-" ] && [ "$INCLUDE_THREADS" = "true" ]; then
        output_metric "process_threads" "$nlwp" "gauge" "$labels"
    fi

    cpu_count=$((cpu_count + 1))
    [ "$cpu_count" -ge "$TOP_N" ] && break

done < <(eval "$PS_CMD" 2>/dev/null | head -$((TOP_N + 10)))

# Get top processes by Memory (only those not already reported)
if [[ "$OSTYPE" != "darwin"* ]]; then
    PS_CMD_MEM="ps -eo pid,ppid,user,%cpu,%mem,rss,vsz,nlwp,comm --sort=-%mem"
else
    PS_CMD_MEM="ps -axo pid,ppid,user,%cpu,%mem,rss,vsz,comm -m"
fi

mem_count=0
while IFS= read -r line; do
    # Skip header line
    if [[ "$line" =~ ^[[:space:]]*PID ]]; then
        continue
    fi

    # Skip empty lines
    [ -z "$line" ] && continue

    # Parse fields
    pid=$(echo "$line" | awk '{print $1}')

    # Skip if already reported
    if is_reported "$pid"; then
        continue
    fi

    ppid=$(echo "$line" | awk '{print $2}')
    user=$(echo "$line" | awk '{print $3}')
    cpu=$(echo "$line" | awk '{print $4}')
    mem=$(echo "$line" | awk '{print $5}')
    rss=$(echo "$line" | awk '{print $6}')
    vsz=$(echo "$line" | awk '{print $7}')

    if [[ "$OSTYPE" == "darwin"* ]]; then
        comm=$(echo "$line" | awk '{for(i=8;i<=NF;i++) printf "%s ", $i; print ""}' | sed 's/[[:space:]]*$//')
        nlwp=""
    else
        nlwp=$(echo "$line" | awk '{print $8}')
        comm=$(echo "$line" | awk '{for(i=9;i<=NF;i++) printf "%s ", $i; print ""}' | sed 's/[[:space:]]*$//')
    fi

    # Skip kernel processes and idle
    [ "$pid" = "0" ] && continue
    [[ "$comm" == *"idle"* ]] && continue

    # Skip if memory is 0.0
    [ "$mem" = "0.0" ] && continue

    # Escape for JSON
    safe_comm=$(json_escape "$comm")
    safe_user=$(json_escape "$user")
    labels="\"pid\": \"$pid\", \"ppid\": \"$ppid\", \"user\": \"$safe_user\", \"command\": \"$safe_comm\""

    # Output metrics
    output_metric "process_cpu_percent" "$cpu" "gauge" "$labels"
    output_metric "process_memory_percent" "$mem" "gauge" "$labels"

    # RSS is in KB, convert to bytes
    if [ -n "$rss" ] && [ "$rss" != "-" ]; then
        rss_bytes=$((rss * 1024))
        output_metric "process_memory_rss_bytes" "$rss_bytes" "gauge" "$labels"
    fi

    # VSZ is in KB, convert to bytes
    if [ -n "$vsz" ] && [ "$vsz" != "-" ]; then
        vsz_bytes=$((vsz * 1024))
        output_metric "process_memory_vsz_bytes" "$vsz_bytes" "gauge" "$labels"
    fi

    # Thread count (Linux only)
    if [ -n "$nlwp" ] && [ "$nlwp" != "-" ] && [ "$INCLUDE_THREADS" = "true" ]; then
        output_metric "process_threads" "$nlwp" "gauge" "$labels"
    fi

    mem_count=$((mem_count + 1))
    [ "$mem_count" -ge "$TOP_N" ] && break

done < <(eval "$PS_CMD_MEM" 2>/dev/null | head -$((TOP_N + 10)))

# Close JSON array
echo ""
echo "]"
