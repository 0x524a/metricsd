#!/bin/bash
# process_monitor plugin for metricsd
# Monitors specific processes with detailed resource usage stats
#
# REQUIREMENTS: Linux with /proc filesystem
#
# Configuration: Reads process list from process_monitor.json
# Expected JSON structure:
# {
#   "name": "process_monitor",
#   "timeout": 30000000000,
#   "enabled": true,
#   "processes": ["nginx", "postgres", "redis-server"]
# }
#
# Metrics collected per process:
# - process_cpu_percent: CPU usage percentage
# - process_memory_rss_bytes: Resident Set Size (physical memory)
# - process_memory_vms_bytes: Virtual Memory Size
# - process_memory_percent: Memory usage as percentage of system total
# - process_threads: Number of threads
# - process_fds: Open file descriptors count
# - process_io_read_bytes: Cumulative bytes read (counter)
# - process_io_write_bytes: Cumulative bytes written (counter)
# - process_uptime_seconds: Process uptime in seconds
# - process_status: Process state (1=running, 2=sleeping, 3=stopped, 4=zombie, 0=not found)
#
# Labels include:
# - process_name: Name from config
# - pid: Process ID
# - cmdline: Command line (truncated)
# - user: Process owner
# - state: Human-readable state (Running, Sleeping, etc.)
#
# Output format: JSON array of metrics following the plugin schema

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/process_monitor.json"

# Start JSON array
echo "["

first=true

# Function to output a metric
output_metric() {
    local name="$1"
    local value="$2"
    local type="${3:-gauge}"
    local labels="$4"

    # Skip if value is empty or not a number
    if [ -z "$value" ] || ! [[ "$value" =~ ^-?[0-9]+\.?[0-9]*$ ]]; then
        return
    fi

    if [ "$first" = true ]; then
        first=false
    else
        echo ","
    fi

    if [ -n "$labels" ]; then
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\", \"labels\": {$labels}}"
    else
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\"}"
    fi
}

# Function to escape string for JSON
json_escape() {
    echo "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g; s/\n/\\n/g'
}

# Check if config file exists
if [ ! -f "$CONFIG_FILE" ]; then
    # No config file, exit with empty array
    echo ""
    echo "]"
    exit 0
fi

# Read process list from config file
if ! command -v jq &> /dev/null; then
    # jq not available, try to parse manually (basic parsing)
    processes=$(grep -o '"processes"[[:space:]]*:[[:space:]]*\[.*\]' "$CONFIG_FILE" | sed 's/.*\[\(.*\)\].*/\1/' | tr -d '"' | tr ',' '\n')
else
    # Use jq for robust parsing
    processes=$(jq -r '.processes[]?' "$CONFIG_FILE" 2>/dev/null || echo "")
fi

# If no processes defined, exit
if [ -z "$processes" ]; then
    echo ""
    echo "]"
    exit 0
fi

# Check if running on Linux
if [ ! -d "/proc" ]; then
    # Not Linux, output empty array
    echo ""
    echo "]"
    exit 0
fi

# Get system uptime for calculating process uptime
system_uptime=$(awk '{print $1}' /proc/uptime 2>/dev/null || echo "0")

# Get total system memory for percentage calculation
total_mem_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')

# Iterate through each configured process
while IFS= read -r proc_name; do
    [ -z "$proc_name" ] && continue

    # Find all PIDs matching the process name
    # Use pgrep for reliable matching
    if command -v pgrep &> /dev/null; then
        pids=$(pgrep -x "$proc_name" 2>/dev/null || pgrep -f "$proc_name" 2>/dev/null || echo "")
    else
        # Fallback to ps
        pids=$(ps -eo pid,comm | grep -w "$proc_name" | awk '{print $1}')
    fi

    if [ -z "$pids" ]; then
        # Process not found - output status=0 metric
        safe_proc_name=$(json_escape "$proc_name")
        labels="\"process_name\": \"$safe_proc_name\", \"state\": \"NotFound\""
        output_metric "process_status" "0" "gauge" "$labels"
        continue
    fi

    # Monitor each PID
    for pid in $pids; do
        [ -z "$pid" ] && continue

        # Check if /proc/<pid> exists
        if [ ! -d "/proc/$pid" ]; then
            continue
        fi

        # Read /proc/<pid>/stat for CPU and state info
        if [ -f "/proc/$pid/stat" ]; then
            stat_data=$(cat "/proc/$pid/stat" 2>/dev/null || echo "")
            if [ -n "$stat_data" ]; then
                # Extract fields from stat file
                # Format: pid (comm) state ppid pgrp session tty_nr tpgid flags minflt cminflt majflt cmajflt utime stime cutime cstime...

                # Extract state (3rd field)
                state=$(echo "$stat_data" | awk '{print $3}')

                # Extract utime (14th) and stime (15th) for CPU calculation
                utime=$(echo "$stat_data" | awk '{print $14}')
                stime=$(echo "$stat_data" | awk '{print $15}')

                # Extract starttime (22nd field) for uptime calculation
                starttime=$(echo "$stat_data" | awk '{print $22}')

                # Extract num_threads (20th field)
                num_threads=$(echo "$stat_data" | awk '{print $20}')
            fi
        fi

        # Read /proc/<pid>/status for memory and detailed info
        if [ -f "/proc/$pid/status" ]; then
            status_data=$(cat "/proc/$pid/status" 2>/dev/null || echo "")

            # Extract memory info
            rss_kb=$(echo "$status_data" | grep -w "VmRSS:" | awk '{print $2}')
            vms_kb=$(echo "$status_data" | grep -w "VmSize:" | awk '{print $2}')

            # Extract FD count
            fd_count=$(echo "$status_data" | grep -w "FDSize:" | awk '{print $2}')

            # Get process owner
            proc_uid=$(echo "$status_data" | grep -w "Uid:" | awk '{print $2}')
            if [ -n "$proc_uid" ]; then
                proc_user=$(getent passwd "$proc_uid" | cut -d: -f1 || echo "$proc_uid")
            else
                proc_user="unknown"
            fi
        fi

        # Read cmdline
        if [ -f "/proc/$pid/cmdline" ]; then
            cmdline=$(cat "/proc/$pid/cmdline" 2>/dev/null | tr '\0' ' ' | sed 's/[[:space:]]*$//' || echo "")
            # Truncate to 100 characters
            cmdline="${cmdline:0:100}"
        else
            cmdline=""
        fi

        # Read I/O stats if available
        if [ -f "/proc/$pid/io" ]; then
            io_data=$(cat "/proc/$pid/io" 2>/dev/null || echo "")
            read_bytes=$(echo "$io_data" | grep -w "read_bytes:" | awk '{print $2}')
            write_bytes=$(echo "$io_data" | grep -w "write_bytes:" | awk '{print $2}')
        fi

        # Calculate CPU percentage (simplified - would need previous sample for accurate %)
        # For now, we'll use ps as fallback for CPU
        cpu_percent=$(ps -p "$pid" -o %cpu= 2>/dev/null | tr -d ' ' || echo "0")

        # Calculate memory percentage
        if [ -n "$rss_kb" ] && [ -n "$total_mem_kb" ] && [ "$total_mem_kb" -gt 0 ]; then
            mem_percent=$(awk "BEGIN {printf \"%.2f\", ($rss_kb / $total_mem_kb) * 100}")
        else
            mem_percent="0"
        fi

        # Calculate uptime
        if [ -n "$starttime" ] && [ -n "$system_uptime" ]; then
            # starttime is in clock ticks since boot, convert to seconds
            clock_ticks=$(getconf CLK_TCK 2>/dev/null || echo "100")
            start_seconds=$(awk "BEGIN {printf \"%.0f\", $starttime / $clock_ticks}")
            uptime_seconds=$(awk "BEGIN {printf \"%.0f\", $system_uptime - $start_seconds}")
            [ "$uptime_seconds" -lt 0 ] && uptime_seconds=0
        else
            uptime_seconds="0"
        fi

        # Convert state to numeric and human-readable
        case "$state" in
            R) state_num=1; state_label="Running" ;;
            S) state_num=2; state_label="Sleeping" ;;
            D) state_num=3; state_label="Waiting" ;;
            Z) state_num=4; state_label="Zombie" ;;
            T) state_num=5; state_label="Stopped" ;;
            t) state_num=5; state_label="Tracing" ;;
            X) state_num=6; state_label="Dead" ;;
            *) state_num=7; state_label="Unknown" ;;
        esac

        # Escape for JSON
        safe_proc_name=$(json_escape "$proc_name")
        safe_cmdline=$(json_escape "$cmdline")
        safe_user=$(json_escape "$proc_user")
        safe_state=$(json_escape "$state_label")

        # Build labels
        labels="\"process_name\": \"$safe_proc_name\", \"pid\": \"$pid\", \"cmdline\": \"$safe_cmdline\", \"user\": \"$safe_user\", \"state\": \"$safe_state\""

        # Output metrics
        output_metric "process_cpu_percent" "$cpu_percent" "gauge" "$labels"

        if [ -n "$rss_kb" ]; then
            rss_bytes=$((rss_kb * 1024))
            output_metric "process_memory_rss_bytes" "$rss_bytes" "gauge" "$labels"
        fi

        if [ -n "$vms_kb" ]; then
            vms_bytes=$((vms_kb * 1024))
            output_metric "process_memory_vms_bytes" "$vms_bytes" "gauge" "$labels"
        fi

        output_metric "process_memory_percent" "$mem_percent" "gauge" "$labels"

        if [ -n "$num_threads" ]; then
            output_metric "process_threads" "$num_threads" "gauge" "$labels"
        fi

        if [ -n "$fd_count" ]; then
            output_metric "process_fds" "$fd_count" "gauge" "$labels"
        fi

        if [ -n "$read_bytes" ]; then
            output_metric "process_io_read_bytes" "$read_bytes" "counter" "$labels"
        fi

        if [ -n "$write_bytes" ]; then
            output_metric "process_io_write_bytes" "$write_bytes" "counter" "$labels"
        fi

        output_metric "process_uptime_seconds" "$uptime_seconds" "gauge" "$labels"
        output_metric "process_status" "$state_num" "gauge" "$labels"

    done

done <<< "$processes"

# Close JSON array
echo ""
echo "]"
