#!/bin/bash
# ubuntu_pro metrics plugin for metricsd
# Collects Ubuntu Pro (formerly Ubuntu Advantage) subscription status
#
# Metrics collected:
# - ubuntu_pro_available: Whether the pro command is available (0/1)
# - ubuntu_pro_attached: Whether Ubuntu Pro is attached/enabled (0/1)
# - ubuntu_pro_service_enabled: Status of each Ubuntu Pro service (0/1 per service)
# - ubuntu_pro_expiry_days: Days until subscription expires
#
# Monitored services: esm-apps, esm-infra, livepatch, usg
#
# Output format: JSON array of metrics following the plugin schema

set -e

# Start JSON array
echo "["

first=true

# Function to output a metric
output_metric() {
    local name="$1"
    local value="$2"
    local type="${3:-gauge}"
    local labels="$4"

    # Skip if value is empty or not a number
    if [ -z "$value" ] || ! [[ "$value" =~ ^-?[0-9]+\.?[0-9]*$ ]]; then
        return
    fi

    if [ "$first" = true ]; then
        first=false
    else
        echo ","
    fi

    if [ -n "$labels" ]; then
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\", \"labels\": {$labels}}"
    else
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\"}"
    fi
}

# Function to escape string for JSON
json_escape() {
    echo "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g; s/\n/\\n/g'
}

# Check if pro command is available
if ! command -v pro &> /dev/null; then
    # Try old ua command (Ubuntu Advantage)
    if ! command -v ua &> /dev/null; then
        output_metric "ubuntu_pro_available" 0 "gauge" ""
        echo ""
        echo "]"
        exit 0
    fi
    PRO_CMD="ua"
else
    PRO_CMD="pro"
fi

# Ubuntu Pro is available
output_metric "ubuntu_pro_available" 1 "gauge" ""

# Get Ubuntu Pro status
pro_status=$($PRO_CMD status --format json 2>/dev/null || $PRO_CMD status 2>/dev/null || echo "")

if [ -z "$pro_status" ]; then
    # Can't get status, just output available metric
    echo ""
    echo "]"
    exit 0
fi

# Check if JSON format is available
if echo "$pro_status" | jq empty 2>/dev/null; then
    # Parse JSON output using jq
    attached=$(echo "$pro_status" | jq -r '.attached // false')

    if [ "$attached" = "true" ]; then
        output_metric "ubuntu_pro_attached" 1 "gauge" ""
    else
        output_metric "ubuntu_pro_attached" 0 "gauge" ""
    fi

    # Parse services (focus on key services: esm-apps, esm-infra, livepatch, usg)
    services=$(echo "$pro_status" | jq -r '.services[]? | "\(.name)|\(.status)"' 2>/dev/null || echo "")

    if [ -n "$services" ]; then
        while IFS='|' read -r service_name service_status; do
            [ -z "$service_name" ] && continue

            safe_service=$(json_escape "$service_name")
            safe_status=$(json_escape "$service_status")

            # Convert status to numeric (enabled=1, disabled/n/a=0)
            if [ "$service_status" = "enabled" ]; then
                status_val=1
            else
                status_val=0
            fi

            labels="\"service\": \"$safe_service\", \"status\": \"$safe_status\""
            output_metric "ubuntu_pro_service_enabled" "$status_val" "gauge" "$labels"
        done <<< "$services"
    fi

    # Get expiry information if attached
    if [ "$attached" = "true" ]; then
        expires=$(echo "$pro_status" | jq -r '.expires // empty' 2>/dev/null)
        if [ -n "$expires" ] && [ "$expires" != "null" ]; then
            # Try to calculate days until expiry
            if command -v date &> /dev/null; then
                # Parse expiry date (format: YYYY-MM-DD or similar)
                expiry_epoch=$(date -d "$expires" +%s 2>/dev/null || echo "")
                if [ -n "$expiry_epoch" ]; then
                    current_epoch=$(date +%s)
                    days_until_expiry=$(( (expiry_epoch - current_epoch) / 86400 ))
                    if [ "$days_until_expiry" -ge 0 ]; then
                        output_metric "ubuntu_pro_expiry_days" "$days_until_expiry" "gauge" ""
                    fi
                fi
            fi
        fi
    fi
else
    # Fallback: Parse text output
    if echo "$pro_status" | grep -qi "This machine is attached"; then
        output_metric "ubuntu_pro_attached" 1 "gauge" ""
    elif echo "$pro_status" | grep -qi "This machine is not attached"; then
        output_metric "ubuntu_pro_attached" 0 "gauge" ""
    fi

    # Try to parse services from text output
    # Format: SERVICE   ENTITLED  STATUS    ...
    while IFS= read -r line; do
        # Skip header and empty lines
        [ -z "$line" ] && continue
        echo "$line" | grep -q "SERVICE" && continue
        echo "$line" | grep -q "^---" && continue

        # Parse service line (whitespace-separated)
        service_name=$(echo "$line" | awk '{print $1}')
        service_status=$(echo "$line" | awk '{print $3}')

        [ -z "$service_name" ] || [ "$service_name" = "SERVICE" ] && continue

        safe_service=$(json_escape "$service_name")
        safe_status=$(json_escape "$service_status")

        # Convert status to numeric
        if echo "$service_status" | grep -qi "enabled"; then
            status_val=1
        else
            status_val=0
        fi

        labels="\"service\": \"$safe_service\", \"status\": \"$safe_status\""
        output_metric "ubuntu_pro_service_enabled" "$status_val" "gauge" "$labels"
    done <<< "$pro_status"
fi

# Close JSON array
echo ""
echo "]"
