#!/bin/bash
# ufw (Uncomplicated Firewall) metrics plugin for metricsd
# Collects firewall status and rule counts from UFW
#
# Metrics collected:
# - ufw_available: Whether ufw is installed (0/1)
# - ufw_enabled: Whether ufw is active (0/1)
# - ufw_rules_total: Total number of firewall rules
# - ufw_rules_ipv4: Number of IPv4 rules
# - ufw_rules_ipv6: Number of IPv6 rules
# - ufw_rules_by_action: Rules count by action (allow/deny/reject/limit)
# - ufw_rules_by_direction: Rules count by direction (in/out)
# - ufw_default_incoming: Default incoming policy (0=deny, 1=allow, 2=reject)
# - ufw_default_outgoing: Default outgoing policy (0=deny, 1=allow, 2=reject)
# - ufw_logging_enabled: Whether logging is enabled (0/1)
#
# Output format: JSON array of metrics following the plugin schema

set -e

# Start JSON array
echo "["

first=true

# Function to output a metric
output_metric() {
    local name="$1"
    local value="$2"
    local type="${3:-gauge}"
    local labels="$4"

    if [ "$first" = true ]; then
        first=false
    else
        echo ","
    fi

    if [ -n "$labels" ]; then
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\", \"labels\": {$labels}}"
    else
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\"}"
    fi
}

# Function to escape string for JSON
json_escape() {
    echo "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g; s/\n/\\n/g'
}

# Function to convert policy string to numeric value
policy_to_num() {
    case "$1" in
        deny|DENY)     echo 0 ;;
        allow|ALLOW)   echo 1 ;;
        reject|REJECT) echo 2 ;;
        *)             echo -1 ;;
    esac
}

# Check if ufw is available
if ! command -v ufw &> /dev/null; then
    output_metric "ufw_available" 0 "gauge" ""
    echo ""
    echo "]"
    exit 0
fi

# ufw is available
output_metric "ufw_available" 1 "gauge" ""

# Get ufw status (requires sudo, but may work if user has permissions)
# Try to get status - if it fails, we'll just report available=1 but no other metrics
ufw_status=$(sudo ufw status verbose 2>/dev/null || ufw status verbose 2>/dev/null || echo "")

if [ -z "$ufw_status" ]; then
    # Can't get status, just output available metric
    echo ""
    echo "]"
    exit 0
fi

# Check if ufw is active
if echo "$ufw_status" | grep -q "Status: active"; then
    output_metric "ufw_enabled" 1 "gauge" ""
else
    output_metric "ufw_enabled" 0 "gauge" ""
fi

# Parse default policies
default_incoming=$(echo "$ufw_status" | grep -i "Default:" | grep -i "incoming" | head -1 | sed 's/.*incoming[[:space:]]*([[:space:]]*\([^)]*\).*/\1/' | tr '[:upper:]' '[:lower:]' | awk '{print $1}')
default_outgoing=$(echo "$ufw_status" | grep -i "Default:" | grep -i "outgoing" | head -1 | sed 's/.*outgoing[[:space:]]*([[:space:]]*\([^)]*\).*/\1/' | tr '[:upper:]' '[:lower:]' | awk '{print $1}')

# Alternative parsing for different ufw output formats
if [ -z "$default_incoming" ]; then
    default_line=$(echo "$ufw_status" | grep -i "Default:" | head -1)
    if [ -n "$default_line" ]; then
        default_incoming=$(echo "$default_line" | awk '{print $2}' | tr -d ',' | tr '[:upper:]' '[:lower:]')
        default_outgoing=$(echo "$default_line" | awk '{print $4}' | tr -d ',' | tr '[:upper:]' '[:lower:]')
    fi
fi

if [ -n "$default_incoming" ]; then
    output_metric "ufw_default_incoming" "$(policy_to_num "$default_incoming")" "gauge" "\"policy\": \"$default_incoming\""
fi

if [ -n "$default_outgoing" ]; then
    output_metric "ufw_default_outgoing" "$(policy_to_num "$default_outgoing")" "gauge" "\"policy\": \"$default_outgoing\""
fi

# Check logging status
if echo "$ufw_status" | grep -qi "Logging:.*on"; then
    output_metric "ufw_logging_enabled" 1 "gauge" ""
else
    output_metric "ufw_logging_enabled" 0 "gauge" ""
fi

# Count rules by parsing ufw status numbered output
rules_output=$(sudo ufw status numbered 2>/dev/null || ufw status numbered 2>/dev/null || echo "")

if [ -n "$rules_output" ]; then
    # Count total rules (lines starting with [ followed by a number)
    # Use grep | wc -l instead of grep -c to avoid exit code 1 with set -e
    total_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | wc -l | tr -d ' ')
    total_rules=${total_rules:-0}
    output_metric "ufw_rules_total" "$total_rules" "gauge" ""

    # Count IPv4 vs IPv6 rules
    ipv6_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep '(v6)' 2>/dev/null | wc -l | tr -d ' ')
    ipv6_rules=${ipv6_rules:-0}
    ipv4_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep -v '(v6)' 2>/dev/null | wc -l | tr -d ' ')
    ipv4_rules=${ipv4_rules:-0}
    output_metric "ufw_rules_ipv4" "$ipv4_rules" "gauge" ""
    output_metric "ufw_rules_ipv6" "$ipv6_rules" "gauge" ""

    # Count rules by action
    allow_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep -i 'ALLOW' 2>/dev/null | wc -l | tr -d ' ')
    allow_rules=${allow_rules:-0}
    deny_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep -i 'DENY' 2>/dev/null | wc -l | tr -d ' ')
    deny_rules=${deny_rules:-0}
    reject_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep -i 'REJECT' 2>/dev/null | wc -l | tr -d ' ')
    reject_rules=${reject_rules:-0}
    limit_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep -i 'LIMIT' 2>/dev/null | wc -l | tr -d ' ')
    limit_rules=${limit_rules:-0}

    output_metric "ufw_rules_by_action" "$allow_rules" "gauge" "\"action\": \"allow\""
    output_metric "ufw_rules_by_action" "$deny_rules" "gauge" "\"action\": \"deny\""
    output_metric "ufw_rules_by_action" "$reject_rules" "gauge" "\"action\": \"reject\""
    output_metric "ufw_rules_by_action" "$limit_rules" "gauge" "\"action\": \"limit\""

    # Count rules by direction
    in_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep -i 'IN' 2>/dev/null | wc -l | tr -d ' ')
    in_rules=${in_rules:-0}
    out_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep -i 'OUT' 2>/dev/null | wc -l | tr -d ' ')
    out_rules=${out_rules:-0}
    fwd_rules=$(echo "$rules_output" | grep '^\[' 2>/dev/null | grep -i 'FWD' 2>/dev/null | wc -l | tr -d ' ')
    fwd_rules=${fwd_rules:-0}

    output_metric "ufw_rules_by_direction" "$in_rules" "gauge" "\"direction\": \"in\""
    output_metric "ufw_rules_by_direction" "$out_rules" "gauge" "\"direction\": \"out\""
    output_metric "ufw_rules_by_direction" "$fwd_rules" "gauge" "\"direction\": \"forward\""
fi

# Close JSON array
echo ""
echo "]"
