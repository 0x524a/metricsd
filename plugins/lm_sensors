#!/bin/bash
# lm_sensors metrics plugin for metricsd
# Collects hardware sensor data (temperatures, fan speeds, voltages) from lm-sensors
#
# Metrics collected:
# - lm_sensors_available: Whether lm-sensors is installed (0/1)
# - sensor_temperature_celsius: Temperature readings from various sensors
# - sensor_fan_rpm: Fan speed readings in RPM
# - sensor_voltage_volts: Voltage readings
# - sensor_power_watts: Power readings (if available)
# - sensor_current_amps: Current readings (if available)
#
# Output format: JSON array of metrics following the plugin schema

set -e

# Start JSON array
echo "["

first=true

# Function to output a metric
output_metric() {
    local name="$1"
    local value="$2"
    local type="${3:-gauge}"
    local labels="$4"

    # Skip if value is empty or not a number
    if [ -z "$value" ] || ! [[ "$value" =~ ^-?[0-9]+\.?[0-9]*$ ]]; then
        return
    fi

    if [ "$first" = true ]; then
        first=false
    else
        echo ","
    fi

    if [ -n "$labels" ]; then
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\", \"labels\": {$labels}}"
    else
        echo "  {\"name\": \"$name\", \"value\": $value, \"type\": \"$type\"}"
    fi
}

# Function to escape string for JSON
json_escape() {
    echo "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g; s/\n/\\n/g'
}

# Check if sensors command is available
if ! command -v sensors &> /dev/null; then
    output_metric "lm_sensors_available" 0 "gauge" ""
    echo ""
    echo "]"
    exit 0
fi

# lm-sensors is available
output_metric "lm_sensors_available" 1 "gauge" ""

# Get sensor output - try running sensors command
sensors_output=$(sensors 2>/dev/null) || sensors_output=""

# If no output or empty, just exit with available=1
if [ -z "$sensors_output" ]; then
    echo ""
    echo "]"
    exit 0
fi

# Parse text output from sensors command
current_adapter=""

while IFS= read -r line; do
    # Skip empty lines
    [ -z "$line" ] && continue

    # Check for adapter line (no leading whitespace, ends with colon or contains "Adapter:")
    if [[ ! "$line" =~ ^[[:space:]] ]] && [[ "$line" != *":"*":"* ]]; then
        current_adapter=$(echo "$line" | sed 's/:$//' | tr -d '\n')
        continue
    fi

    # Parse sensor readings
    # Format: "sensor_name:  +value unit (other info)"
    if [[ "$line" =~ ^[[:space:]]*([^:]+):[[:space:]]*([+-]?[0-9]+\.?[0-9]*)[[:space:]]*([^[:space:]]+) ]]; then
        sensor_name="${BASH_REMATCH[1]}"
        value="${BASH_REMATCH[2]}"
        unit="${BASH_REMATCH[3]}"

        # Clean up sensor name and value
        sensor_name=$(echo "$sensor_name" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        value=$(echo "$value" | tr -d '+')

        # Escape for JSON
        safe_adapter=$(json_escape "$current_adapter")
        safe_sensor=$(json_escape "$sensor_name")
        labels="\"adapter\": \"$safe_adapter\", \"sensor\": \"$safe_sensor\""

        # Determine metric type based on unit
        case "$unit" in
            °C|C)
                output_metric "sensor_temperature_celsius" "$value" "gauge" "$labels"
                ;;
            RPM)
                output_metric "sensor_fan_rpm" "$value" "gauge" "$labels"
                ;;
            V)
                output_metric "sensor_voltage_volts" "$value" "gauge" "$labels"
                ;;
            W)
                output_metric "sensor_power_watts" "$value" "gauge" "$labels"
                ;;
            A)
                output_metric "sensor_current_amps" "$value" "gauge" "$labels"
                ;;
        esac
    fi
done <<< "$sensors_output"

# Close JSON array
echo ""
echo "]"
